{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "pine",
      "camelcase": "Pine",
      "scope": "source.pine",
      "path": ".",
      "file-types": ["pine", "pinescript"],
      "injection-regex": "^pine$"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Pine Script v6 grammar for tree-sitter (merged kvarenzn base + enum)",
    "authors": [{ "name": "HyperFrequency" }],
    "links": {
      "repository": "https://github.com/HyperFrequency/pinelsp"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
